# HRMS Environment Variables for Production
# Copy this file to .env and update values

# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef12

# Token expiry in minutes (default: 480 = 8 hours)
TOKEN_EXPIRE_MINUTES=480

# Debug mode (set to false for production)
DEBUG=false

# Allowed CORS origins (comma-separated) - your domain
ALLOWED_ORIGINS=*

# PostgreSQL Database (main database) - Docker uses 'postgres' hostname
DATABASE_URL=postgresql://hrms_user:hrms_password@postgres:5432/hrms_db

# External MySQL Database (for inquiry sync from Hostinger)
EXTERNAL_DB_HOST=mysql3131258.hostingerserve.com
